<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>ガチャゲーム</title>

<style>
body{
    font-family: Arial, sans-serif;
    text-align:center;
    background: linear-gradient(135deg,#1e3c72,#2a5298);
    color:white;
    margin-top:50px;
}

h1{
    font-size:40px;
}

#result{
    margin-top:30px;
    font-size:28px;
    font-weight:bold;
}

button{
    padding:15px 40px;
    font-size:20px;
    border:none;
    border-radius:10px;
    background:#ffd700;
    cursor:pointer;
    transition:0.2s;
}

button:hover{
    transform:scale(1.1);
}

.card{
    margin:30px auto;
    width:200px;
    height:250px;
    border-radius:15px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    font-weight:bold;
}

.star5{
    background:linear-gradient(45deg,#ffd700,#fff3a0);
    color:black;
}

.star4{
    background:linear-gradient(45deg,#a64dff,#d8b3ff);
}

.star3{
    background:linear-gradient(45deg,#4da6ff,#b3d9ff);
}
</style>
</head>

<body>

<h1>🎮 ガチャゲーム</h1>

<button onclick="gacha()">ガチャを引く！</button>

<div id="card"></div>
<div id="result"></div>

<script>

const characters = [
    {name:"勇者", rarity:5},
    {name:"魔法使い", rarity:4},
    {name:"騎士", rarity:4},
    {name:"弓使い", rarity:3},
    {name:"盗賊", rarity:3},
    {name:"僧侶", rarity:3}
];

function gacha(){

    let rand = Math.random();
    let rarity;

    if(rand < 0.05){
        rarity = 5; //5%
    }else if(rand < 0.25){
        rarity = 4; //20%
    }else{
        rarity = 3; //75%
    }

    let pool = characters.filter(c => c.rarity === rarity);
    let result = pool[Math.floor(Math.random()*pool.length)];

    let card = document.getElementById("card");
    card.className = "card star" + rarity;
    card.innerHTML = "★".repeat(rarity);

    document.getElementById("result").innerHTML =
        "「" + result.name + "」をゲット！";
}

</script>

</body>
</html>
